{
  "name": "@chocbite/ts-lib-settings",
  "version": "1.4.0",
  "description": "UI settings handler for TypeScript",
  "author": "chocolateandmilkwin",
  "license": "MIT",
  "type": "module",
  "private": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 9956",
    "build": "tsdown src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "upgrades": "npx npm-check-updates --target semver",
    "upgrade": "npx npm-check-updates --target semver -u && npm install"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.2",
    "eslint": "^9.39.4",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@chocbite/ts-lib-result": "^1.3.0",
    "@chocbite/ts-lib-state": "^2.0.4"
  }
}
